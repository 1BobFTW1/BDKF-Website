---
interface Props { current?: string }
const { current = '' } = Astro.props;

const items = [
  { href: '/', label: 'Start', key: 'start' },
  { href: '/katzen/', label: 'Katzen', key: 'katzen' },
  { href: '/helfen/', label: 'Helfen', key: 'helfen' },
  { href: '/verein/', label: 'Verein', key: 'verein' },
];
---
<header class="nav">
  <a class="nav-logo" href="/" aria-label="Bund der Katzenfreunde — zur Startseite">
    {/* Wort-Bild-Marke, Höhe ≈ 1/16 der Bezugsgröße (Viewporthöhe) —
        beide Varianten im DOM, der Kontrast-Switch blendet um */}
    <img class="logo-black" src="/assets/logos/black/bdkf-wortbildmarke-tight.svg" alt="" width="895" height="465" />
    <img class="logo-white" src="/assets/logos/white/bdkf-wortbildmarke-white-tight.svg" alt="" width="895" height="465" />
  </a>
  <nav aria-label="Hauptnavigation">
    <ul>
      {items.map((i) => (
        <li>
          <a href={i.href} data-label={i.label} aria-current={current === i.key ? 'page' : undefined}>{i.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  /* Farb-Mitnahme: die Leiste übernimmt die Hintergrundfarbe der Fläche,
     die gerade unter ihrer Mittellinie liegt. Farbige Sektionen tragen
     data-nav-bg="<CSS-Farbe>", dunkle zusätzlich data-nav-dark (schaltet
     .on-dark: Logo + Links auf Weiß). Ohne Treffer: Weiß.
     getBoundingClientRect berücksichtigt auch GSAP-Pins/Transforms;
     bei Überlappung gewinnt die spätere Fläche im DOM (= obere z-Ebene). */
  const nav = document.querySelector('.nav');
  const surfaces = Array.from(document.querySelectorAll('[data-nav-bg]'));
  if (nav && surfaces.length) {
    const update = () => {
      const mid = nav.getBoundingClientRect().height / 2;
      let bg = '';
      let dark = false;
      for (const el of surfaces) {
        const r = el.getBoundingClientRect();
        if (r.top < mid && r.bottom > mid) {
          bg = el.dataset.navBg || '';
          dark = el.hasAttribute('data-nav-dark');
        }
      }
      nav.style.background = bg || 'var(--white)';
      nav.classList.toggle('on-dark', dark);
    };
    addEventListener('scroll', update, { passive: true });
    addEventListener('resize', update);
    update();
  }
</script>

<style>
  /* Fixiert am oberen Rand: bleibt beim Scrollen stehen, liegt über allem
     Seiteninhalt (auch über gepinnten GSAP-Flächen). Der Hintergrund wird
     per Script an die Fläche darunter angeglichen ([data-nav-bg]) —
     auf dunklen Flächen schaltet .on-dark Logo und Links auf Weiß. */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    /* Logo und Links vertikal mittig zueinander, symmetrisches Padding */
    align-items: center;
    justify-content: space-between;
    gap: var(--gutter);
    padding: clamp(16px, 2.5svh, 32px) var(--margin);
    background: var(--white);
    transition: background-color 0.25s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav { transition: none; }
  }

  .nav-logo { display: block; line-height: 0; }
  .nav-logo img { height: clamp(40px, 6.25svh, 56px); width: auto; }

  .nav .logo-white { display: none; }
  .nav.on-dark .logo-black { display: none; }
  .nav.on-dark .logo-white { display: block; }
  .nav.on-dark nav a { color: var(--white); }

  /* Links: versal, rechtsbündig über die rechte Hälfte verteilt */
  nav { flex: 1 1 auto; max-width: 50%; margin-left: auto; }

  nav ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 6px clamp(16px, 2.5vw, 40px);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  nav a {
    display: inline-block;
    text-align: center;
    font-weight: var(--fw-text);
    text-transform: uppercase;
    text-decoration: none;
    font-size: var(--fs-text);
    line-height: 1.2;
    transition: color 0.2s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    nav a { transition: none; }
  }

  /* Breite auf Bold-Maß reservieren, damit beim Fett-Werden nichts springt */
  nav a::after {
    content: attr(data-label);
    display: block;
    height: 0;
    overflow: hidden;
    visibility: hidden;
    font-weight: var(--fw-bold);
  }

  nav a:hover,
  nav a:focus-visible,
  nav a[aria-current='page'] {
    font-weight: var(--fw-bold);
  }

  @media (max-width: 720px) {
    .nav { flex-direction: column; align-items: flex-start; gap: 14px; }
    nav { max-width: none; margin-left: 0; width: 100%; }
    nav ul { justify-content: flex-start; }
  }
</style>
