---
import Base from '../layouts/Base.astro';

// TODO: Platzhalter — News von bund-der-katzenfreunde.de, mit Verein abgleichen
const news = [
  { datum: '28.05.2026', titel: 'Tapsi & Mietz suchen ein Zuhause', text: 'Zwei, die zusammengehören: neugierige Tapsi und die anfangs schüchterne Mietz.' },
  { datum: '10.05.2026', titel: 'Melissa stellt sich vor', text: 'Eine sanfte Seele mit Vergangenheit sucht Menschen mit Geduld.' },
  { datum: '24.02.2026', titel: 'Pflege- und Endplätze gesucht', text: 'Wir suchen dringend Sofas auf Zeit — Tierarztkosten übernehmen wir.' },
  { datum: '02.02.2026', titel: 'Willy & Leila sind angekommen', text: 'Happy End: gemeinsam eingezogen, gemeinsam glücklich.' },
  { datum: '07.12.2025', titel: 'Katzen aus schlechter Haltung gerettet', text: 'Mehrere Katzen konnten übernommen und versorgt werden.' },
  { datum: '08.07.2025', titel: 'Oma Lisa hat ihr Für-immer-Zuhause', text: 'Mit 14 Jahren noch einmal angekommen.' },
  { datum: '19.06.2025', titel: 'Notfallkater Willi', text: 'Willi braucht Menschen, die ihm Zeit geben.' },
  { datum: '01.05.2025', titel: 'Karli ist vermittelt', text: 'Vom Notfall zum Sofakönig.' },
];

// TODO: Platzhalter — Termine mit Verein abgleichen
const termine = [
  { datum: '05.07.2026', titel: 'Viecherlmesse', ort: 'Nazareth-Kirche, München' },
  { datum: '06.09.2026', titel: 'Herbst-Flohmarkt', ort: 'ASZ Fürstenried-West' },
  { datum: '22.11.2026', titel: 'Weihnachtsflohmarkt', ort: 'St. Maximilian' },
];
---
<Base title="Aktuelles & Termine | Bund der Katzenfreunde e. V." current="aktuelles">
  <!-- Kopf: Text links auf Weiß, Teilfläche rechts, crazy-cat halb über der Kante -->
  <section class="kopf sec">
    <div class="sec-head pad-x">
      <p class="eyebrow">Aktuelles</p>
      <h1 class="display"><span class="nb">Neues aus</span> <span class="nb">dem Verein.</span></h1>
    </div>
    <div
      class="form-row"
      style="--c: var(--coral); --form-w: 55%; --cat-w: clamp(120px, 15vw, 210px); --cat-ar: 1.44; --cat-in: clamp(30px, 4vw, 60px)"
    >
      <img
        class="illu form-cat front reveal-fade"
        src="/assets/illustrations/crazy-cat-tight.svg"
        alt=""
        width="858"
        height="597"
      />
      <div class="form-block kopf-form"></div>
    </div>
  </section>

  <!-- News -->
  <section id="news" class="news pad-x sec">
    <ul class="news-list">
      {news.map((n) => (
        <li>
          <span class="news-datum">{n.datum}</span>
          <div>
            <h2 class="news-titel">{n.titel}</h2>
            <p>{n.text}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- Termine: Teilfläche rechts -->
  <section id="termine" class="termine sec">
    <div class="sec-head pad-x">
      <p class="eyebrow">Termine</p>
      <h2 class="display"><span class="nb">Wir sehen</span> <span class="nb">uns. Miau.</span></h2>
    </div>
    <div class="form-row" style="--c: var(--coral); --form-w: 62%; --cat-w: 0px; --cat-ar: 1">
      <div class="form-block">
        <ul class="termine-list">
          {termine.map((t) => (
            <li>
              <span class="termine-datum">{t.datum}</span>
              <span class="termine-titel">{t.titel}</span>
              <span>{t.ort}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</Base>

<style>
  .kopf { padding-top: clamp(24px, 6svh, 72px); }
  .kopf-form { min-height: clamp(140px, 24svh, 240px); }

  .news { margin-top: clamp(96px, 15vw, 220px); }

  .news-list { margin: 0; padding: 0; list-style: none; }

  .news-list li {
    display: grid;
    grid-template-columns: 7em 1fr;
    gap: 2px var(--gutter);
    padding: clamp(16px, 2.2vw, 28px) 0;
    border-top: 2px solid var(--black);
    max-width: 76ch;
  }
  .news-list li:last-child { border-bottom: 2px solid var(--black); }

  .news-datum { font-weight: var(--fw-bold); }

  .news-titel {
    margin: 0 0 0.3em;
    font-size: var(--fs-sub);
    font-weight: var(--fw-text);
    line-height: 0.9;
    text-transform: uppercase;
  }

  .termine { margin-top: clamp(96px, 15vw, 220px); }

  .termine-list { margin: 0; padding: 0; list-style: none; }

  .termine-list li {
    display: grid;
    grid-template-columns: 7em 1fr;
    gap: 2px var(--gutter);
    padding: clamp(12px, 1.6vw, 20px) 0;
    border-top: 2px solid var(--black);
    max-width: 62ch;
  }

  .termine-datum { font-weight: var(--fw-bold); grid-row: span 2; }
  .termine-titel { font-weight: var(--fw-bold); text-transform: uppercase; }
  .termine-list li > span:last-child { grid-column: 2; }

  @media (max-width: 560px) {
    .news-list li { grid-template-columns: 1fr; }
  }
</style>
