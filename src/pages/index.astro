---
import Base from '../layouts/Base.astro';

import katzenRaw from '../data/katzen.json';

// Neuankömmlinge: die 5 neuesten Vermittlungskatzen aus den echten Daten
// (katzen.json ist vom Scraper bereits neueste-zuerst sortiert) —
// 3 sind sichtbar, durch die restlichen scrollt GSAP horizontal durch
function shortText(t) {
  // Emojis (z. B. ❤️) wirken im Original als Satzgrenze — durch Punkt ersetzen
  const s = t.replace(/^update[^:]*:\s*/i, '').replace(/\s*[❤♥]️?\s*/gu, '. ');
  const m = s.match(/^[\s\S]{40,160}?[.!?…](?=\s|$)/);
  return m ? m[0].trim() : `${s.slice(0, 140).trim()}…`;
}

const katzen = katzenRaw.slice(0, 5).map((k) => ({
  slug: k.slug,
  name: k.title.replace(/\s*\+\s*/g, ' & '),
  text: shortText(k.beschreibung),
  photo: k.images[0],
}));

// Termine von bund-der-katzenfreunde.de (Stand 14.07.2026)
const termine = [
  { datum: '06.09.2026', titel: 'Herbst-Flohmarkt', ort: 'ASZ Fürstenried-West, Züricher Str. 80, München' },
  { datum: '22.11.2026', titel: 'Weihnachtsflohmarkt', ort: 'Pfarrsaal St. Maximilian, Deutingerstr. 4, München' },
];
---
<Base title="Bund der Katzenfreunde e. V. — Katzen adoptieren in München" current="start">
  <!-- Hero nach Figma (306:80): viel Weißraum — Textspalte links,
       Farbfläche nur rechte Hälfte unten (3/8 Höhe), lying-cat über deren
       Kante, großer CTA mit Mini-Katze hinter der Buttonkante -->
  <section class="hero sec">
    <div class="hero-head pad-x">
      <h1 class="display">Dein Sofa<br />hat noch<br />Platz frei</h1>
    </div>
    {/* Untere Zeile: links Intro + CTA auf Weiß, rechts die halbe Farbfläche
        (wie Figma) — sie füllt die volle Resthöhe bis zum Fold, die Sektion
        darunter erscheint erst beim Scrollen. Katze mittig auf der Oberkante. */}
    <div class="hero-body">
      <div class="hero-lower pad-x">
        <p class="hero-intro">
          Der Bund der Katzenfreunde e.&nbsp;V. vermittelt Katzen in München und Umgebung
          in gute Hände — mit Beratung, Pflegeplätzen und einem Verein, der zusammenhält.
        </p>
        <div class="hero-cta">
          <img
            class="illu hero-cta-cat"
            src="/assets/illustrations/peeking-cat-tight.svg"
            alt=""
            width="779"
            height="491"
          />
          <a class="btn hero-btn" href="/katzen/">Katze adoptieren</a>
        </div>
      </div>
      <div class="hero-form" style="--c: var(--yellow)">
        <img
          class="illu hero-form-cat"
          src="/assets/illustrations/lying-cat-tight.svg"
          alt=""
          width="794"
          height="818"
        />
      </div>
    </div>
  </section>

  <!-- Katzen-Teaser: die 5 Neuankömmlinge — erste Sektion nach dem Hero,
       schiebt sich über den gepinnten Hero-Text und die rutschende Katze -->
  <section class="teaser pad-x sec" data-nav-bg="var(--yellow)">
    <div class="sec-head">
      <h2 class="display"><span class="nb">Wer wartet</span> <span class="nb">heute</span> <span class="nb">auf dich?</span></h2>
    </div>
    {/* 5 Karten im 3er-Raster: der Track ist breiter als die Sektion und
        wird beim Scrollen von GSAP horizontal durchgeschoben */}
    <div class="teaser-clip">
      <div class="cards teaser-track">
        {katzen.map((k) => (
          <article class="card">
            {/* Deep-Link: öffnet auf der Katzen-Seite direkt die Detailansicht */}
            <a href={`/katzen/#${k.slug}`}>
              <div class="card-media teaser-media">
                <img class="teaser-photo" src={k.photo} alt={k.name} loading="lazy" />
              </div>
              <h3 class="card-name">{k.name}</h3>
            </a>
            <p class="card-text">{k.text}</p>
          </article>
        ))}
      </div>
    </div>
    <p class="gap-8"><a class="btn btn-ghost" href="/katzen/">Alle Katzen ansehen</a></p>
  </section>

  <!-- Drei Wege zu helfen -->
  <section class="wege pad-x sec" data-nav-bg="var(--black)" data-nav-dark>
    <div class="sec-head">
      <h2 class="display"><span class="nb">Drei Wege</span> <span class="nb">zu helfen</span></h2>
    </div>
    <ul class="wege-list">
      <li>
        <a href="/katzen/">
          <span class="wege-name">Adoptieren</span>
          <span>Gib einer Katze ein Zuhause für immer.</span>
        </a>
      </li>
      <li>
        <a href="/helfen/#pflegeplatz">
          <span class="wege-name">Pflegeplatz geben</span>
          <span>Ein Sofa auf Zeit — wir übernehmen die Tierarztkosten.</span>
        </a>
      </li>
      <li>
        <a href="/helfen/#pate">
          <span class="wege-name">Pate werden</span>
          <span>Unterstütze eine Katze, die (noch) nicht vermittelt werden kann.</span>
        </a>
      </li>
    </ul>
  </section>

  <!-- Termine: Teilfläche rechts, lying-cat hängt über der Kante -->
  <section class="termine sec">
    <div class="sec-head pad-x">
      {/* &shy; = weiche Trennstelle: bricht nur bei Platzmangel (Mobile)
          als SCHNURR-STRACKS um, Desktop bleibt ungetrennt */}
      <h2 class="display"><span class="nb">Schnurr&shy;stracks zu</span> <span class="nb">unseren Events</span></h2>
    </div>
    <div
      class="form-row"
      style="--c: var(--red); --form-w: 75%; --cat-w: clamp(150px, 19vw, 270px); --cat-ar: 1.44; --cat-in: 0px"
    >
      <img
        class="illu form-cat front"
        src="/assets/illustrations/crazy-cat-tight.svg"
        alt=""
        width="858"
        height="597"
      />
      <div class="form-block">
        <ul class="termine-list">
          {termine.map((t) => (
            <li>
              <span class="termine-datum">{t.datum}</span>
              <span class="termine-titel">{t.titel}</span>
              <span>{t.ort}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Mitmachen: komplette Sektion auf Gruen (wie die Drei-Wege-Sektion
       auf Schwarz), Typo bleibt schwarz -->
  <section class="spenden sec" data-nav-bg="var(--green)">
    <div class="sec-head pad-x">
      <h2 class="display"><span class="nb">Grosses Herz</span> <span class="nb">fuer kleine</span> <span class="nb">Pfoten?</span> <span class="nb">Mach mit!</span></h2>
    </div>
    <div class="pad-x">
      <p class="spenden-copy">
        Jeder Beitrag hilft: Tierarztkosten, Futter, Kastrationen. Oder du machst es
        offiziell und wirst Teil des Vereins.
      </p>
      <p class="gap-8 spenden-actions">
        <a class="btn" href="/verein/#mitglied">Mitglied werden</a>
        <a class="btn btn-ghost" href="/helfen/#spenden">Spenden</a>
      </p>
    </div>
  </section>
</Base>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
    gsap.registerPlugin(ScrollTrigger);
    // @ts-ignore — für Debugging in der Konsole erreichbar
    window.ScrollTrigger = ScrollTrigger;

    /* Mobile (< 720px, wie der Nav-Breakpoint): keine Pins, kein Kippen,
       kein Scroll-Lock — die Choreografien setzen Desktop-Geometrie voraus
       und Scroll-Hijacking fühlt sich auf Touch falsch an. Es bleiben die
       dezenten Einblendungen; der Teaser wird per CSS nativ swipebar. */
    const desktop = matchMedia('(min-width: 720px)').matches;

    /* ---------- Entrance: dezent gestaffeltes Aufblenden ----------
       Einheitliche Lade-Formsprache auf allen Seiten: nur Fade + kleiner
       Versatz (≤ 24 px), kurze Dauern, enge Staffelung — keine weiten
       Flüge quer über die Seite.
       WICHTIG: Die STARTZUSTAENDE (opacity 0 + Versatz) setzt CSS unter
       html.motion — schon vor dem ersten Paint. Hier wird nur noch per
       .to() zum Endzustand animiert: kein sichtbar→versteckt→sichtbar-
       Flickern beim Laden mehr. */
    const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });
    tl.to('.hero-head .display', { y: 0, opacity: 1, duration: 0.6 })
      .to('.hero-intro', { y: 0, opacity: 1, duration: 0.5 }, '-=0.35')
      .to('.hero-cta', { y: 0, opacity: 1, duration: 0.5 }, '-=0.35')
      .to('.hero-form', { opacity: 1, duration: 0.6 }, 0.15)
      .to('.hero-form-cat', { y: 0, opacity: 1, duration: 0.5 }, '-=0.3');

    /* Rutsche: beim Scrollen kippt der gelbe Balken (Drehpunkt rechts unten,
       die linke Kante senkt sich) — und die lying-cat rutscht die schiefe
       Oberkante hinunter, aus dem Bild. Die nachfolgende Teaser-Sektion
       ("Wer wartet heute auf dich?", z-Ebene 2) schiebt sich dabei über
       die rutschende Katze. Farbe und Breite des Balkens bleiben unberührt. */
    if (desktop) {
    const heroForm = document.querySelector('.hero-form');
    const heroCat = document.querySelector('.hero-form-cat');
    const coverEl = document.querySelector('.teaser');
    // Fallhöhe: von der Ausgangslage bis komplett unter die Teaser-Oberkante
    // (im unverformten Zustand gemessen — invalidateOnRefresh setzt zurück)
    // Fallstrecke in BILDSCHIRM-Pixeln (senkrecht nach unten, bis komplett
    // hinter der Teaser-Oberkante). Da die lokalen Achsen der Katze durch die
    // 45°-Kippung diagonal liegen, wird der senkrechte Fall unten in gleiche
    // x-/y-Anteile zerlegt (cos 45° ≈ 0,707).
    const dropPx = () => {
      const catBottomDoc = heroCat.getBoundingClientRect().bottom + window.scrollY;
      const coverTopDoc = coverEl.getBoundingClientRect().top + window.scrollY;
      return coverTopDoc - catBottomDoc + heroCat.offsetHeight + 120;
    };
    const slide = gsap.timeline({
      defaults: { ease: 'none' },
      scrollTrigger: {
        trigger: '.teaser',
        // Scrub-Weg im gleichen Verhältnis verlängert wie die Timeline
        // (1,75 → 2 Einheiten): Grad pro Scroll-Pixel bleiben unverändert
        start: 'top bottom',
        end: 'top 30%',
        scrub: true,
        invalidateOnRefresh: true,
      },
    });
    slide
      // Balken klappt um volle 90° ab (Drehpunkt rechts unten, Rotation GEGEN
      // den Uhrzeigersinn — die linke Kante taucht steil nach unten).
      // Doppelte Dauer bei verlängertem Scrub-Weg: die Kipp-
      // GESCHWINDIGKEIT bleibt exakt wie bei der 45°-Fassung, es kippt nur
      // weiter, wenn man weiterscrollt.
      .to(heroForm, { rotate: -90, transformOrigin: 'right bottom', duration: 2 }, 0)
      // die Katze rutscht GLEICHZEITIG die Schräge nach links hinunter —
      // weiches Ein-/Ausgleiten entlang der gekippten Kante
      .to(heroCat, { x: () => -heroForm.offsetWidth * 0.36, ease: 'power1.inOut', duration: 1 }, 0)
      // ...und fällt am Ende senkrecht hinter die Teaser-Sektion.
      // Senkrecht in Bildschirm-Pixeln = lokal (−0,707 · d, +0,707 · d),
      // weil die lokalen Achsen der Katze um −45° mitgedreht sind.
      .to(heroCat, {
        x: () => -heroForm.offsetWidth * 0.36 - 0.707 * dropPx(),
        y: () => 0.707 * dropPx(),
        rotate: 8,
        ease: 'power2.in',
        duration: 0.9,
      }, '>-0.15');

    /* Hero-Text (Headline, Intro, CTA) bleibt beim Scrollen stehen (Pin ab
       Ausgangslage) — die gelbe Teaser-Sektion (z-Ebene 2) schiebt sich
       darüber und deckt ihn zu. Sobald ihre Oberkante den Viewport-Anfang
       erreicht, löst sich der Pin. */
    ['.hero-head', '.hero-lower'].forEach((sel) => {
      const el = document.querySelector(sel);
      const docTop = el.getBoundingClientRect().top + window.scrollY;
      ScrollTrigger.create({
        trigger: el,
        start: `top ${docTop}px`,
        endTrigger: '.teaser',
        end: 'top top',
        pin: true,
        pinSpacing: false,
      });
    });
    }

    /* ---------- Scroll-Reveals für die Sektionen ----------
       Wie beim Hero-Entrance: Startzustaende kommen aus CSS (html.motion,
       vor dem ersten Paint), hier wird nur per .to() zum Endzustand
       animiert — kein Flickern beim Reinscrollen. */
    document.querySelectorAll('.wege .sec-head, .teaser .sec-head, .termine .sec-head, .spenden .sec-head').forEach((el) => {
      gsap.to(el, {
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 88%' },
      });
    });

    // Drei Wege: Zeilen staffeln sich ein
    gsap.to('.wege-list li', {
      y: 0,
      opacity: 1,
      duration: 0.6,
      stagger: 0.12,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.wege-list', start: 'top 85%' },
    });

    // Neuankömmlinge: erst ganz zur gelben Sektion scrollen (Unterkante am
    // Viewport-Boden), dann pinnt sie — der weitere Vertikal-Scroll wird
    // 1:1 in den Horizontal-Scrub des 5er-Tracks übersetzt, danach löst
    // der Pin und es geht normal vertikal weiter
    const teaserTrack = document.querySelector('.teaser-track');
    const teaserClip = document.querySelector('.teaser-clip');
    if (desktop && teaserTrack && teaserClip) {
      const overhang = () => teaserTrack.scrollWidth - teaserClip.offsetWidth;
      gsap.to(teaserTrack, {
        x: () => -overhang(),
        ease: 'none',
        scrollTrigger: {
          trigger: '.teaser',
          start: 'bottom bottom',
          end: () => `+=${overhang()}`,
          scrub: true,
          pin: true,
          invalidateOnRefresh: true,
        },
      });
    }

    // Neuankömmlinge: Karten tauchen gestaffelt auf
    ScrollTrigger.batch('.teaser .card', {
      start: 'top 90%',
      once: true,
      onEnter: (batch) =>
        gsap.to(batch, { y: 0, opacity: 1, duration: 0.7, stagger: 0.12, ease: 'power2.out', overwrite: true }),
    });

    // Termine: Rot-Fläche fährt von rechts herein, die Katze legt sich danach drauf
    gsap.to('.termine .form-block', {
      x: 0,
      duration: 0.9,
      ease: 'power3.out',
      scrollTrigger: { trigger: '.termine .form-row', start: 'top 78%' },
    });
    gsap.to('.termine .form-cat', {
      y: 0,
      opacity: 1,
      duration: 0.7,
      delay: 0.35,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.termine .form-row', start: 'top 78%' },
    });

    // Wie beim Teaser ueber dem Hero: die rote Termine-Sektion rastet ein,
    // sobald ihre Unterkante den Viewport-Boden erreicht, die "Mach mit"-
    // Sektion schiebt sich beim Weiterscrollen darueber und deckt sie zu
    if (desktop) {
      ScrollTrigger.create({
        trigger: '.termine',
        start: 'bottom bottom',
        endTrigger: '.spenden',
        end: 'top top',
        pin: true,
        pinSpacing: false,
      });
    }

    // Mach mit: Copy + Buttons blenden gestaffelt auf
    gsap.to('.spenden .spenden-copy, .spenden .spenden-actions', {
      y: 0,
      opacity: 1,
      duration: 0.6,
      stagger: 0.12,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.spenden .spenden-copy', start: 'top 85%' },
    });
  }
</script>

<style>
  /* hereinfahrende Flächen dürfen währenddessen keinen horizontalen
     Overflow/Scrollbalken erzeugen (clip statt hidden: vertikale Überhänge
     wie die Termine-Katze bleiben sichtbar) */
  .hero, .termine, .spenden { overflow-x: clip; }
</style>

<style is:global>
  /* Startseite: Footer grenzt direkt an die grüne Mach-mit-Sektion.
     Der Peek-Slot wird um seine eigene Höhe nach oben gezogen — das schwarze
     Band beginnt damit an der grünen Kante, die Katze schaut vor Grün über
     die Band-Oberkante. z-Ebene 2, damit die Katze nicht hinter der grünen
     Sektion (ebenfalls z2, früher im DOM) verschwindet. */
  .footer.sec {
    position: relative;
    z-index: 2;
    margin-top: 0;
    /* eigener Formatierungskontext: verhindert, dass die negative Marge
       des Peek-Slots mit der Footer-Marge kollabiert und die (klickfeste)
       Footer-Box ueber die Buttons der gruenen Sektion hochzieht — so ragt
       nur der pointer-events-freie Slot hinueber */
    display: flow-root;
  }
  .footer.sec .footer-cat {
    /* Slot-Höhe = Katzenbreite / Seitenverhältnis (779/491 ≈ 1,586) */
    margin-top: calc(-1 * clamp(210px, 22.5vw, 345px) / 1.586);
  }
</style>

<style>
  /* Teaser-Fotos: immer quadratisch, flächenfüllend (wie im Katzen-Grid) */
  .teaser-media { aspect-ratio: 1; }
  .teaser-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Entrance-Startzustaende: greifen VOR dem ersten Paint (html.motion wird
     synchron im <head> gesetzt), GSAP blendet per .to() zum Endzustand.
     Ohne Motion (reduced motion / kein JS-Gate) bleibt alles sichtbar. */
  :global(html.motion) .hero-head .display,
  :global(html.motion) .hero-form-cat {
    opacity: 0;
    transform: translateY(24px);
  }

  :global(html.motion) .hero-intro,
  :global(html.motion) .hero-cta {
    opacity: 0;
    transform: translateY(16px);
  }

  :global(html.motion) .hero-form {
    opacity: 0;
  }

  /* Scroll-Reveal-Startzustaende (gleiches Prinzip): die GSAP-.to()-Tweens
     blenden beim Reinscrollen zum Endzustand */
  :global(html.motion) .wege .sec-head,
  :global(html.motion) .teaser .sec-head,
  :global(html.motion) .termine .sec-head,
  :global(html.motion) .spenden .sec-head,
  :global(html.motion) .teaser-track :global(.card) {
    opacity: 0;
    transform: translateY(24px);
  }

  :global(html.motion) .wege-list li,
  :global(html.motion) .spenden-copy,
  :global(html.motion) .spenden-actions {
    opacity: 0;
    transform: translateY(20px);
  }

  :global(html.motion) .termine .form-block {
    transform: translateX(110%);
  }

  :global(html.motion) .termine .form-cat {
    opacity: 0;
    transform: translateY(60px);
  }

  /* ---------- Hero (Figma 306:80) ---------- */
  .hero {
    --catw: clamp(220px, 26vw, 340px);
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: calc(100svh - var(--nav-h));
  }

  /* Weiße Kopfzone: nur die Headline, oben, volle Breite. Etwas mehr Luft
     nach oben, damit der Titel näher an den Text darunter rückt. */
  .hero-head {
    padding-top: clamp(40px, 9svh, 110px);
    padding-bottom: clamp(20px, 3svh, 36px);
  }
  .hero-head h1 { width: fit-content; max-width: 100%; }

  /* Untere Zeile: Text links auf Weiß, direkt unter der Headline; die
     Farbfläche ist absolut in der Sektion verankert (rechte Hälfte × 3/8) */
  .hero-body {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .hero-lower {
    display: flex;
    flex-direction: column;
    width: 50%;
    padding-top: clamp(8px, 2svh, 24px);
    padding-bottom: clamp(28px, 5svh, 64px);
  }

  .hero-intro { max-width: 40ch; }

  /* CTA: schwarze Fläche, Mini-Katze lugt bei Hover/Fokus seitlich aus der
     rechten Kante heraus (90° gedreht, schiebt sich horizontal raus) */
  .hero-cta {
    position: relative;
    display: inline-block;
    align-self: flex-start;
    margin-top: clamp(20px, 3svh, 40px);
  }

  /* Basis-Transform zentriert die Katze auf der rechten Buttonkante
     (50/50-Überhang) und dreht sie quer; das letzte translateY läuft nach
     der Drehung entlang der Bildachse = horizontal auf dem Screen und
     schiebt sie hinter den Button (Button hat z-index 1, Katze z 0). */
  .hero-cta-cat {
    position: absolute;
    left: 100%;
    top: 50%;
    width: clamp(56px, 6vw, 80px);
    height: auto;
    transform: translate(-50%, -50%) rotate(90deg) translateY(55%);
    transition: transform 0.4s cubic-bezier(0.19, 0.75, 0.27, 1);
  }

  /* ausgefahren: die Katze schaut komplett raus — nur die flache Schnitt-
     kante des Bilds bleibt minimal hinter dem Button verankert (negatives
     translateY schiebt nach der Drehung nach rechts aus der Kante) */
  .hero-cta:hover .hero-cta-cat,
  .hero-cta:focus-within .hero-cta-cat {
    transform: translate(-50%, -50%) rotate(90deg) translateY(-45%);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-cta-cat { transition: none; }
  }

  /* CTA-Text auf der Textstufe (16); große Klickfläche über Padding —
     die schwarze Fläche bleibt plakativ, die Typo im rigiden Raster */
  .hero-btn {
    position: relative;
    z-index: 1;
    font-weight: var(--fw-text);
    font-size: var(--fs-text);
    padding: 1.75em 3.5em;
  }

  /* Farbfläche: rechte Hälfte × 3/8 der Sektionshöhe, an rechter und unterer
     Kante der Sektion angedockt (Figma-Proportionen).
     top-verankert (62,5 % + 37,5 % = Unterkante), damit das GSAP-Höhen-
     wachstum beim Morph nach UNTEN läuft — Richtung grüner Balken. */
  .hero-form {
    position: absolute;
    /* rechts um 38vw über den Viewport hinaus verlängert: beim Kippen wirkt
       die rechte Kante nicht abgeschnitten — sichtbar bleiben 50 % Breite */
    right: -38vw;
    top: 62.5%;
    width: calc(50% + 38vw);
    /* senkrecht nach unten verlängert — mehr Gelb unterhalb der Sektions-
       kante (die Oberkante mit der Katze bleibt, wo sie ist) */
    height: calc(37.5% + clamp(160px, 24vh, 360px));
    background: var(--c);
  }

  /* lying-cat mittig auf der Oberkante der Form — exakt halb drüber, halb
     drauf (Figma: 50/50-Überhang). Zentrierung über left-calc statt
     transform (kollidiert sonst mit reveal-fade). AR lying-cat ≈ 0.97. */
  .hero-form-cat {
    position: absolute;
    z-index: 2;
    /* mittig auf dem SICHTBAREN Teil der Form (38vw ragen rechts raus) */
    left: calc((100% - 38vw) / 2 - var(--catw) / 2);
    bottom: calc(100% - var(--catw) / 0.97 / 2);
    width: var(--catw);
    height: auto;
  }

  /* ---------- Drei Wege ---------- */
