---
import BaseV2 from '../layouts/BaseV2.astro';
import Nav from '../components/v2/Nav.astro';
import Footer from '../components/v2/Footer.astro';
---
<BaseV2 title="Verein — Bund der Katzenfreunde" description="Über den Bund der Katzenfreunde e. V.: Mitgliedschaft, Satzung und wer wir sind.">
  <Nav current="verein" />

  <section class="page-intro wrap">
    <p class="v2-eyebrow">Verein</p>
    <h1 class="v2-head">Der&nbsp;Verein</h1>
    <p class="v2-sub">
      Der Bund der Katzenfreunde e.&thinsp;V. ist ein ehrenamtlicher
      Katzenschutzverein aus München — ohne eigenes Tierheim, dafür mit
      einem Netz aus Pflegefamilien, Futterstellen und Menschen, die
      anpacken. Wir sind Mitglied im Deutschen Tierschutzbund.
    </p>
  </section>

  <section class="section wrap" id="mitgliedschaft">
    <div class="split">
      <div>
        <h2 class="v2-sub section-h accent-line">Mitgliedschaft</h2>
        <p class="v2-body">
          Als Mitglied unterstützt du unsere Arbeit auf die einfachste Art:
          verlässlich, jedes Jahr, ohne dass du dafür ein Katzenklo anfassen
          musst. Einfach die Beitrittserklärung ausfüllen — das SEPA-Mandat
          macht es für beide Seiten bequem — und per Post an uns schicken.
        </p>
        <ul class="v2-body downloads">
          <!-- TODO: Platzhalter — echte PDF-Formulare verlinken -->
          <li><a href="/kontakt/">Beitrittserklärung (PDF) ↓</a></li>
          <li><a href="/kontakt/">SEPA-Mandat / Einzugsermächtigung (PDF) ↓</a></li>
        </ul>
        <p class="v2-body addr">
          <!-- TODO: Platzhalter — Postadresse von der bestehenden Website, vor Livegang bestätigen -->
          Bund der Katzenfreunde e.&thinsp;V.<br />
          c/o Marius Zisselsberger<br />
          Oberhachinger Str. 24&thinsp;a, 82031 Grünwald
        </p>
      </div>
      <div class="field"></div>
    </div>
  </section>

  <section class="section wrap" id="satzung">
    <h2 class="v2-sub section-h">Satzung</h2>
    <p class="v2-body satzung-p">
      Wer genau wissen will, wofür wir stehen: Unsere Satzung regelt Zweck,
      Gemeinnützigkeit und Organe des Vereins.
      <!-- TODO: Platzhalter — Satzungs-PDF verlinken -->
      <a href="/kontakt/">Satzung lesen (PDF) ↓</a>
    </p>
  </section>

  <div class="cta-zone">
    <img
      class="illu cta-cat reveal"
      src="/assets/illustrations/fat-cat-filled.svg"
      alt=""
      width="570"
      height="441"
      loading="lazy"
    />
    <section class="cta-band">
      <div class="wrap cta-grid">
        <h2 class="v2-sub cta-h">Werde Mitglied. Schnurren inklusive.</h2>
        <a class="btn cta-btn" href="#mitgliedschaft">Beitrittserklärung holen</a>
      </div>
    </section>
  </div>

  <Footer />
</BaseV2>

<style>
  .section-h {
    margin-bottom: clamp(20px, 2.5vw, 32px);
  }
  .accent-line {
    border-left: 10px solid var(--c-verein);
    padding-left: 18px;
  }
  .split {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: calc(var(--v2-gap) * 2);
  }
  .split .v2-body {
    max-width: 58ch;
  }
  .field {
    background: var(--c-verein);
    min-height: 220px;
  }
  .downloads {
    list-style: none;
    display: grid;
    gap: 8px;
    margin-block: 20px;
    font-weight: 700;
  }
  .downloads a {
    color: inherit;
    text-decoration: none;
  }
  .downloads a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .addr {
    color: var(--v2-navy);
  }
  .satzung-p {
    max-width: 58ch;
  }
  .satzung-p a {
    font-weight: 700;
    color: inherit;
  }

  .cta-zone {
    position: relative;
    /* Platz für die Katze (Seitenverhältnis 441/570 ≈ 0.78) */
    margin-top: calc(clamp(160px, 19vw, 250px) * 0.78 + 28px);
  }
  .cta-cat {
    position: absolute;
    bottom: 100%;
    left: clamp(24px, 10vw, 170px);
    width: clamp(160px, 19vw, 250px);
    margin-bottom: -2px;
  }
  .cta-band {
    background: color-mix(in srgb, var(--c-verein) 32%, var(--v2-paper));
    padding-block: clamp(44px, 5vw, 72px);
    /* Band ÜBER der Katze: Reveal taucht hinter der Kante auf */
    position: relative;
    z-index: 1;
  }
  .cta-grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--v2-gap);
    flex-wrap: wrap;
  }
  .cta-h {
    font-weight: 700;
    text-transform: uppercase;
  }
  @media (max-width: 900px) {
    .split {
      grid-template-columns: 1fr;
    }
    .field {
      min-height: 120px;
      order: -1;
    }
  }
</style>
