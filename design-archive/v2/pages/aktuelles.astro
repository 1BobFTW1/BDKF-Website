---
import BaseV2 from '../layouts/BaseV2.astro';
import Nav from '../components/v2/Nav.astro';
import Footer from '../components/v2/Footer.astro';

const news = [
  { datum: '28.05.2026', titel: 'Tapsi + Mietz', text: 'Die beiden suchen gemeinsam ein Zuhause — am liebsten mit Fensterplatz für zwei.' },
  { datum: '10.05.2026', titel: 'Melissa', text: 'Vom abgemagerten Notfall zur Schmusekatze: Melissas Geschichte macht Mut.' },
  { datum: '24.02.2026', titel: 'Pflege- bzw. Endplätze gesucht', text: 'Für mehrere Katzen suchen wir dringend Pflegestellen — auch befristet hilft.' },
  { datum: '02.02.2026', titel: 'Willy + Leila', text: 'Happy End: Die beiden sind gemeinsam in ihr neues Zuhause gezogen.' },
  { datum: '07.12.2025', titel: 'Katzen aus schlechter Haltung', text: 'Mehrere Tiere aus einer Wohnungsauflösung sind bei uns in Sicherheit.' },
  { datum: '08.07.2025', titel: 'Oma Lisa', text: 'Mit 14 Jahren noch einmal angekommen — für ein Zuhause ist es nie zu spät.' },
  { datum: '19.06.2025', titel: 'Notfallkater Willi', text: 'Willi braucht Spezialfutter und Geduld — Paten gesucht.' },
  { datum: '01.05.2025', titel: 'Karli', text: 'Vom scheuen Fundkater zum Wohnungstiger mit festem Fensterplatz.' },
];
---
<BaseV2 title="Aktuelles — Bund der Katzenfreunde" description="Neuigkeiten und Termine des Bund der Katzenfreunde e. V.">
  <Nav current="aktuelles" />

  <section class="page-intro wrap intro-with-cat">
    <div>
      <p class="v2-eyebrow">Aktuelles</p>
      <h1 class="v2-head">Neues aus dem&nbsp;Verein</h1>
      <p class="v2-sub">
        Erst Zoomies, dann Schmusen — was unsere Katzen und das Flohmarkt-Team
        gerade beschäftigt.
      </p>
    </div>
    <img
      class="illu crazy-cat reveal"
      src="/assets/illustrations/crazy-cat-filled.svg"
      alt=""
      width="707"
      height="491"
    />
  </section>

  <section class="section wrap" id="news">
    <h2 class="v2-sub section-h">Neuigkeiten</h2>
    <ul class="news v2-body">
      {news.map((n) => (
        <li class="news-item">
          <span class="news-date">{n.datum}</span>
          <div>
            <h3 class="v2-body news-h">{n.titel}</h3>
            <p class="news-text">{n.text}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <section class="section wrap" id="termine">
    <h2 class="v2-sub section-h">Termine</h2>
    <ol class="events v2-body">
      <li class="event">
        <span class="event-date">05.07.2026</span>
        <span class="event-name">Viecherlmesse bei Pfarrer Schießler</span>
        <span class="event-place">10:30–12:00 · Nazareth-Kirche, Barbarossastr. 3, 81677 München</span>
      </li>
      <li class="event">
        <span class="event-date">06.09.2026</span>
        <span class="event-name">Herbst-Flohmarkt Fürstenried</span>
        <span class="event-place">10:00–15:00 · ASZ Fürstenried-West, Züricher Str. 80, 81476 München</span>
      </li>
      <li class="event">
        <span class="event-date">22.11.2026</span>
        <span class="event-name">Großer Weihnachtsflohmarkt</span>
        <span class="event-place">10:00–15:00 · Pfarrsaal St. Maximilian, Deutingerstr. 4, 80469 München</span>
      </li>
    </ol>
    <p class="v2-body helper-note">
      Du willst am Stand helfen? <a href="/helfen/#ehrenamt">Wir suchen immer Flohmarkt-Helfer.</a>
    </p>
  </section>

  <Footer />
</BaseV2>

<style>
  .intro-with-cat {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: var(--v2-gap);
  }
  .crazy-cat {
    width: clamp(150px, 20vw, 280px);
  }
  .section-h {
    margin-bottom: clamp(24px, 3vw, 40px);
  }
  .news {
    list-style: none;
  }
  .news-item {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 8px 24px;
    padding-block: 18px;
    border-top: 1px solid #e3e1da;
  }
  .news-item:last-child {
    border-bottom: 1px solid #e3e1da;
  }
  .news-date {
    font-weight: 700;
    color: var(--v2-navy);
  }
  .news-h {
    font-weight: 700;
    text-transform: uppercase;
  }
  .news-text {
    color: var(--v2-navy);
    max-width: 62ch;
  }
  .events {
    list-style: none;
  }
  .event {
    display: grid;
    grid-template-columns: 130px 1.2fr 1.6fr;
    gap: 8px 24px;
    padding: 18px;
    align-items: baseline;
    background: color-mix(in srgb, var(--c-aktuell) 16%, var(--v2-paper));
    border-top: 4px solid var(--c-aktuell);
    margin-bottom: var(--v2-gap);
  }
  .event-date {
    font-weight: 700;
  }
  .event-name {
    font-weight: 700;
    text-transform: uppercase;
  }
  .event-place {
    color: var(--v2-navy);
  }
  .helper-note {
    margin-top: 18px;
  }
  .helper-note a {
    font-weight: 700;
    color: inherit;
  }
  @media (max-width: 820px) {
    .intro-with-cat {
      grid-template-columns: 1fr;
    }
    .news-item,
    .event {
      grid-template-columns: 110px 1fr;
    }
    .event-place {
      grid-column: 2;
    }
  }
</style>
