---
import BaseV2 from '../layouts/BaseV2.astro';
import Nav from '../components/v2/Nav.astro';
import Footer from '../components/v2/Footer.astro';

const artikel = [
  {
    titel: 'Warum Kastrieren so wichtig ist',
    teaser:
      'Eine unkastrierte Katze kann in wenigen Jahren tausende Nachkommen haben — Kastration ist der wirksamste Tierschutz.',
  },
  {
    titel: 'Was Sie wissen sollten',
    teaser:
      'Kosten, Zeit, Urlaub, Allergien: die ehrliche Checkliste, bevor eine Katze einzieht.',
  },
  {
    titel: 'Gefahrenquellen für Katzen',
    teaser:
      'Kippfenster, Lilien, Waschmaschine — die unterschätzten Gefahren im Katzenhaushalt.',
  },
  {
    titel: 'Katzensichere Wohnung',
    teaser:
      'Balkon vernetzen, Fenster sichern, Rückzugsorte schaffen: So wird die Wohnung zum sicheren Revier.',
  },
  {
    titel: 'Unsauberkeit bei Katzen',
    teaser:
      'Wenn die Katze das Klo meidet, hat das Gründe — meist Stress oder Schmerzen. Was wirklich hilft.',
  },
];
---
<BaseV2 title="Katzenwissen — Bund der Katzenfreunde" description="Kastration, Sicherheit, Haltung: Wissen rund um Katzen vom Bund der Katzenfreunde.">
  <Nav current="wissen" />

  <section class="page-intro wrap">
    <p class="v2-eyebrow">Katzenwissen</p>
    <h1 class="v2-head">Gut zu&nbsp;wissen</h1>
    <p class="v2-sub">
      Geh ich dir schon durch den Kopf? Dann lies dich ein: Alles, was du
      vor und mit einer Katze wissen solltest — aus über 20 Jahren
      Vereinserfahrung.
    </p>
  </section>

  <div class="intro-band-zone">
    <img
      class="illu bighead-cat reveal"
      src="/assets/illustrations/big-head-cat-filled.svg"
      alt=""
      width="514"
      height="459"
      loading="lazy"
    />
    <div class="intro-band"></div>
  </div>

  <section class="section wrap">
    <div class="artikel">
      {artikel.map((a) => (
        <article class="art">
          <h2 class="v2-body art-h">{a.titel}</h2>
          <p class="v2-body art-p">{a.teaser}</p>
          <!-- TODO: Platzhalter — eigene Artikelseiten anlegen und verlinken -->
          <a class="v2-body art-link" href="/kontakt/">Weiterlesen →</a>
        </article>
      ))}
    </div>
  </section>

  <Footer />
</BaseV2>

<style>
  .intro-band-zone {
    position: relative;
    /* Platz für die Katze (Seitenverhältnis 459/514 ≈ 0.9) */
    margin-top: calc(clamp(150px, 17vw, 230px) * 0.9 + 28px);
  }
  .bighead-cat {
    position: absolute;
    bottom: 100%;
    right: clamp(24px, 14vw, 220px);
    width: clamp(150px, 17vw, 230px);
    margin-bottom: -2px;
  }
  .intro-band {
    background: var(--c-wissen);
    height: clamp(64px, 8vw, 110px);
    /* Band ÜBER der Katze: Reveal taucht hinter der Kante auf */
    position: relative;
    z-index: 1;
  }
  .artikel {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: calc(var(--v2-gap) * 1.5);
  }
  .art {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 26px 24px;
    background: color-mix(in srgb, var(--c-wissen) 18%, var(--v2-paper));
    border-top: 10px solid var(--c-wissen);
  }
  .art-h {
    font-weight: 700;
    text-transform: uppercase;
  }
  .art-p {
    color: var(--v2-navy);
    max-width: 52ch;
  }
  .art-link {
    font-weight: 700;
    color: inherit;
    text-decoration: none;
    margin-top: auto;
  }
  .art-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  @media (max-width: 820px) {
    .artikel {
      grid-template-columns: 1fr;
    }
  }
</style>
