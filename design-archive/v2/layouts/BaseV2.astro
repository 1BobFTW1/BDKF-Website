---
/**
 * Basis-Layout für die Hauptseite (neues Brand-System „Form + Illustration").
 * Bewusst OHNE ViewportFrame/Mark des alten Systems — die alte Seite lebt
 * unverändert unter /v1/ mit Base.astro.
 */
import '../styles/global.css';
import '../styles/v2.css';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Bund der Katzenfreunde — das Netzwerk für Menschen und ihre Katzen in der Stadt.',
} = Astro.props;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" id="favicon" />
    <link rel="stylesheet" href="https://use.typekit.net/fzx4lwp.css" />
    <script>
      // Tab-aware Favicon wie in Base.astro (Katze duckt sich bei Tabwechsel)
      const favicon = document.getElementById('favicon') as HTMLLinkElement;
      new Image().src = '/favicon-ears.svg';
      const duck = () => {
        favicon.href = document.visibilityState === 'hidden' ? '/favicon-ears.svg' : '/favicon.svg';
      };
      duck();
      document.addEventListener('visibilitychange', duck);

      // Reveal-Grundzustand nur mit JS aktivieren (kein unsichtbarer Inhalt,
      // falls das Skript nicht lädt); reduced motion greift global via CSS.
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body class="v2-body-root">
    <slot />
    <script>
      // Katzen tauchen hinter den Formkanten auf, sobald sie ins Bild kommen.
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.35 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>

<style>
  .v2-body-root {
    background: var(--v2-paper);
    color: var(--v2-ink);
  }
</style>
