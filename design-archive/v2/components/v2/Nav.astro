---
/**
 * Hauptnavigation der neuen Seite: cat-ears-logo links, Links rechts.
 */
interface Props {
  current?: string;
}
const { current = '' } = Astro.props;

const links = [
  { href: '/', label: 'Start', key: 'start' },
  { href: '/vermittlung/', label: 'Vermittlung', key: 'vermittlung' },
  { href: '/helfen/', label: 'Helfen', key: 'helfen' },
  { href: '/katzenwissen/', label: 'Katzenwissen', key: 'wissen' },
  { href: '/verein/', label: 'Verein', key: 'verein' },
  { href: '/aktuelles/', label: 'Aktuelles', key: 'aktuelles' },
  { href: '/kontakt/', label: 'Kontakt', key: 'kontakt' },
];
---
<header class="nav">
  <a href="/" class="logo" aria-label="Bund der Katzenfreunde — Startseite">
    <img src="/assets/logos/cat-ears-logo.svg" alt="" width="480" height="256" />
  </a>
  <nav aria-label="Hauptnavigation">
    <ul class="links">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class:list={{ on: current === l.key }}
            aria-current={current === l.key ? 'page' : undefined}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 22px var(--v2-margin);
  }
  .logo img {
    width: auto;
    height: 52px;
    display: block;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 24px;
    justify-content: flex-end;
    list-style: none;
    font-size: var(--v2-fs-body);
    font-weight: 500;
  }
  .links a {
    color: inherit;
    text-decoration: none;
  }
  .links a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .links a.on {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
  }
  @media (max-width: 720px) {
    .nav {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }
    .logo img {
      height: 44px;
    }
    .links {
      justify-content: flex-start;
      gap: 4px 18px;
    }
  }
</style>
